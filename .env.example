# Mattermost Configuration (for IDEAS to DASHBOARD automation)
MATTERMOST_URL=https://your-mattermost-instance.com
MATTERMOST_TOKEN=your_admin_personal_access_token
MATTERMOST_TEAM_ID=your_team_id
MATTERMOST_WEBHOOK_SECRET=random_secret_for_webhook_verification

# How to get these values:
# 1. MATTERMOST_URL: Your Mattermost instance URL (e.g., https://chat.example.com)
# 2. MATTERMOST_TOKEN: System Admin → Profile → Personal Access Tokens → Create Token
# 3. MATTERMOST_TEAM_ID: Main Menu → Team Settings → View Team ID
# 4. MATTERMOST_WEBHOOK_SECRET: Generate a random string (e.g., openssl rand -hex 32)
